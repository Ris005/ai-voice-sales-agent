# Copy to .env for local runs (optional). All values have safe defaults.

# Leave blank to use the built-in rule-based agent (no API cost, works offline).
# Set to a real key to use a live LLM for the conversation + summaries.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Branding shown in the UI and used by the agent.
COMPANY_NAME=Nimbus CRM
AGENT_NAME=Aria

# Where the Excel CRM lives. Defaults to ./data/leads.xlsx if unset.
# CRM_PATH=./data/leads.xlsx
